<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/left_drawer"
    android:layout_width="336dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@color/ghostex_sidebar_background"
    android:orientation="vertical"
    android:padding="12dp"
    tools:ignore="Overdraw">

    <!-- CDXC:AndroidSidebar 2026-05-17-20:12: The Ghostex sidebar is an overlay drawer included inside TermuxActivity, so it needs its own opaque dark surface to match macOS sidebar contrast even though lint cannot infer that this is not the activity root background. -->

    <!-- CDXC:AndroidConnectionManagement 2026-05-18-02:58: Keep machine switching and setup controls on a dedicated Machines drawer page so the sessions page stays focused on remote ZMX sessions. The top-right Machines/Sessions buttons are in-page navigation, not platform dialogs. -->

    <LinearLayout
        android:id="@+id/ghostex_sessions_page"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/ghostex_drawer_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ghostex_drawer_title"
                android:textColor="@color/ghostex_sidebar_foreground"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ghostex_open_machines_page_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="88dp"
                android:text="@string/ghostex_drawer_machines"
                android:textAllCaps="false"
                android:textColor="@color/ghostex_sidebar_foreground"
                app:backgroundTint="@color/ghostex_sidebar_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/ghostex_connection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/ghostex_drawer_initial_status"
            android:textColor="@color/ghostex_sidebar_muted"
            android:textSize="12sp" />

        <ListView
            android:id="@+id/terminal_sessions_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:cacheColorHint="@android:color/transparent"
            android:choiceMode="singleChoice"
            android:divider="@color/ghostex_sidebar_button"
            android:dividerHeight="8dp"
            android:listSelector="@drawable/ghostex_drawer_session_selector"
            android:longClickable="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ghostex_machines_page"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/ghostex_machines_page_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ghostex_drawer_machines"
                android:textColor="@color/ghostex_sidebar_foreground"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ghostex_back_to_sessions_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="88dp"
                android:text="@string/ghostex_drawer_sessions"
                android:textAllCaps="false"
                android:textColor="@color/ghostex_sidebar_foreground"
                app:backgroundTint="@color/ghostex_sidebar_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/ghostex_machines_page_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/ghostex_drawer_initial_status"
            android:textColor="@color/ghostex_sidebar_muted"
            android:textSize="12sp" />

        <ScrollView
            android:id="@+id/ghostex_machines_page_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/ghostex_machines_page_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ghostex_retry_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/ghostex_drawer_retry"
                android:textAllCaps="false"
                android:textColor="@color/ghostex_sidebar_background"
                app:backgroundTint="@color/ghostex_sidebar_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/new_session_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/ghostex_drawer_add"
                android:textAllCaps="false"
                android:textColor="@color/ghostex_sidebar_foreground"
                app:backgroundTint="@color/ghostex_sidebar_button" />
        </LinearLayout>

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ghostex_open_tailscale_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/ghostex_drawer_tailscale"
                android:textAllCaps="false"
                android:textColor="@color/ghostex_sidebar_foreground"
                app:backgroundTint="@color/ghostex_sidebar_button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ghostex_prepare_phone_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/ghostex_drawer_setup"
                android:textAllCaps="false"
                android:textColor="@color/ghostex_sidebar_foreground"
                app:backgroundTint="@color/ghostex_sidebar_button" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
