<?xml version="1.0" encoding="utf-8"?>
<!-- CDXC:AndroidNotifications 2026-05-27-05:31: Notification RemoteViews do not allow arbitrary touch animations, but session rows should still show a visible pressed/focused state while the user taps a session target. Keep the normal state transparent so the rows remain on the platform notification surface. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#1F95D7F6" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#1F95D7F6" />
        </shape>
    </item>
    <item android:drawable="@android:color/transparent" />
</selector>
